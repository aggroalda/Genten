# Genten Status — Variables de Entorno
# Copiar este archivo a ~/.hermes/.env o configurar como variables del sistema

# Token de Notion API (obligatorio)
# Obtener en: https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxx

# Hash SHA256 de la contraseña del admin (opcional, default: "genten2026")
# Generar con: python3 -c "import hashlib; print(hashlib.sha256(b'tu_password').hexdigest())"
GENTEN_ADMIN_HASH=09a52287a64ec5721a963513bfbb314fade866f26e350e49595642721371b141

# Puerto del servidor (opcional, default: 8080)
PORT=8080
